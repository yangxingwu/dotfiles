{
  "permissions": {
    "allow": [
      "Bash(bash -n *)",
      "Bash(shellcheck *)",
      "Bash(shfmt *)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(./install.sh --dry-run*)",
      "Bash(./install.sh --module * --dry-run)"
    ],
    "deny": [
      "Bash(./install.sh)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Read(~/.ssh/**)",
      "Read(~/.gnupg/**)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-edit.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-stop.sh"
          }
        ]
      }
    ]
  }
}
